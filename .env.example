# AI Provider API Keys (optional — fallback chain: Groq -> Gemini -> OpenAI)
GROQ_API_KEY=gsk_REPLACE_WITH_YOUR_KEY
GEMINI_API_KEY=your-gemini-api-key-here
OPENAI_API_KEY=your-openai-api-key-here

# Upstash Redis (optional — falls back to in-memory rate limiting)
UPSTASH_REDIS_REST_URL=https://your-upstash-redis-url
UPSTASH_REDIS_REST_TOKEN=your-upstash-redis-token

# Supabase (required for newsletter persistence & analytics)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Analytics stats endpoint protection (optional)
ANALYTICS_API_KEY=your-secret-analytics-api-key

# IndexNow SEO submission (optional)
INDEXNOW_API_KEY=your-indexnow-api-key

# Resend email delivery (optional — newsletter & welcome emails)
RESEND_API_KEY=re_REPLACE_WITH_YOUR_KEY

# Newsletter unsubscribe token signing (required if using newsletter features)
UNSUBSCRIBE_SECRET=your-secret-key-min-32-chars-for-hmac

# Google Analytics (optional)
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# Google AdSense (optional)
NEXT_PUBLIC_ADSENSE_ID=ca-pub-XXXXXXXXXX

# Sentry error tracking (optional — production error reporting)
SENTRY_DSN=https://your-sentry-dsn-here@sentry.io/project-id
